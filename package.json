{
  "name": "figma-design-context",
  "version": "1.3.8",
  "description": "MCP server that transforms Figma API data into AI-friendly formats for LLM code generation",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "debug-web/index.html",
    "doc/",
    "README.md"
  ],
  "bin": {
    "figma-design-context": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:debug": "node -e \"process.env.FIGMA_DEBUG='1'; import('./dist/index.js')\"",
    "debug:web": "npm run build && node dist/debug-server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "npm version patch && git push origin main --tags",
    "release:minor": "npm version minor && git push origin main --tags",
    "release:major": "npm version major && git push origin main --tags"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "ai",
    "design",
    "llm",
    "code-generation",
    "design-tokens",
    "tailwind",
    "css",
    "svg",
    "figma-api",
    "ai-context",
    "claude",
    "cursor"
  ],
  "author": "Songlb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boboluo832-dev/figma-design-context.git"
  },
  "homepage": "https://github.com/boboluo832-dev/figma-design-context#readme",
  "bugs": {
    "url": "https://github.com/boboluo832-dev/figma-design-context/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
